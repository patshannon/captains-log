# GitHub personal access token (needs `repo` scope for private repos)
PERSONAL_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API key for Claude
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Comma-separated list of GitHub orgs/users to scrape commits from
GITHUB_ORGS=patshannon,bboxdigital,lavitrine

# Your GitHub username (used to filter commits by author)
GITHUB_USERNAME=patshannon

# Output directory for log files (default: logs/)
LOG_DIR=logs
